<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="inventory_view_form" model="ir.ui.view">
            <field name="name">inventory.item.form</field>
            <field name="model">inventory.item</field>
            <field name="arch" type="xml">
                <form string="Barang Inventaris">
                    <sheet>
                        <group>
                            <group string="Informasi Barang">
                                <field name="item_id"/>
                                <field name="description"/>
                                <field name="stocks"/>
                            </group>
                            <group string="Status &amp; Kategori">
                                <field name="status"/>
                                <field name="category_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="inventory_view_form_detail" model="ir.ui.view">
            <field name="name">inventory.item.form.detail</field>
            <field name="model">inventory.item</field>
            <field name="arch" type="xml">
                <form string="Detail Barang" create="false" edit="false" delete="false">
                    <sheet>
                        <group>
                            <group string="Informasi Barang">
                                <field name="item_id" readonly="1"/>
                                <field name="description" readonly="1"/>
                                <field name="stocks" readonly="1"/>
                            </group>
                            <group string="Status &amp; Kategori">
                                <field name="status" readonly="1"/>
                                <field name="category_ids" widget="many2many_tags" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button string="Tutup" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="inventory_category_view_form" model="ir.ui.view">
            <field name="name">inventory.category.form</field>
            <field name="model">inventory.category</field>
            <field name="arch" type="xml">
                <form string="Kategori Inventaris">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="inventory_category_view_tree" model="ir.ui.view">
            <field name="name">inventory.category.tree</field>
            <field name="model">inventory.category</field>
            <field name="arch" type="xml">
                <tree string="Kategori Inventaris" editable="bottom">
                    <field name="name"/>
                </tree>
            </field>
        </record>

    </data>
</odoo>
