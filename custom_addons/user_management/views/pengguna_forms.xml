<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_pengguna_form" model="ir.ui.view">
        <field name="name">pengguna.form</field>
        <field name="model">user_management.pengguna</field>
        <field name="arch" type="xml">

            <form string="Pengguna">

                <sheet>

                    <group>
                        <field name="nama"/>
                        <field name="user_id"/>
                        <field name="jabatan"/>
                        <field name="divisi"/>
                        <field name="hak_akses"/>
                        <field name="status_aktif"/>
                        <field name="catatan"/>
                    </group>

                </sheet>

            </form>

        </field>
    </record>

</odoo>