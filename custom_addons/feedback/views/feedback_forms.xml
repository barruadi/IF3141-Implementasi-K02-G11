<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="feedback_view_form" model="ir.ui.view">
            <field name="name">feedback.feedback.form</field>
            <field name="model">feedback.feedback</field>
            <field name="arch" type="xml">
                <form string="Feedback Pelanggan">
                    <sheet>

                        <div class="oe_title">
                            <h1>
                                <field name="no_feedback" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group string="Informasi Reservasi">
                                <field name="reservasi_id"/>
                                <field name="customer_id" readonly="1"/>
                                <field name="tanggal_kunjungan" readonly="1"/>
                            </group>

                            <group string="Detail Feedback">
                                <field name="tanggal_feedback"/>
                                <field name="rating" widget="radio"/>
                            </group>
                        </group>

                        <group string="Catatan Ulasan">
                            <field name="catatan_feedback" nolabel="1" placeholder="Tuliskan ulasan dan saran dari pelanggan di sini..."/>
                        </group>

                        <group string="Informasi Audit">
                            <group>
                                <field name="created_at" readonly="1"/>
                                <field name="created_by" readonly="1"/>
                            </group>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
